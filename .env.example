# Copy this file to .env and fill in your values.
# .env is git-ignored and must never be committed.
#
# In RELEASE builds, API_URL is injected at build time:
#   flutter build apk --dart-define=API_URL=https://your-api.com/api/v1
#
# In DEBUG builds, this file is loaded automatically by flutter_dotenv.

API_URL=https://your-backend-link

